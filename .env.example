# ============================================
# Falsisters Server — Environment Variables
# ============================================
# Copy this to .env and fill in the values.
# .env is gitignored, .env.example is safe to commit.

# --- Database (Required) ---
# PostgreSQL connection string. On Railway, this is auto-generated by the
# Postgres service and exposed as ${{Postgres.DATABASE_URL}}.
DATABASE_URL="postgresql://user:password@host:5432/database"

# --- JWT (Required) ---
# Random 32+ character string for signing JWT tokens.
JWT_SECRET="replace-with-a-strong-random-string"

# --- Server (Optional) ---
# Port the server listens on. Defaults to 3001.
# PORT=3001

# --- Storage: MinIO / S3 (choose one section) ---

# Option A: MinIO on Railway (recommended for new deployments)
# S3_ENDPOINT="https://minio.railway.app"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY_ID="minio-access-key"
# S3_SECRET_ACCESS_KEY="minio-secret-key"
# S3_BUCKET_NAME="falsisters-bucket"
# S3_FORCE_PATH_STYLE="true"

# Option B: Supabase Storage (legacy, for backward compat)
# When SUPABASE_PROJECT_URL is set, the server uses public URLs instead of
# signed URLs. Keep empty on Railway to use MinIO signed URL mode.
# SUPABASE_PROJECT_URL="https://your-project.supabase.co"
# SUPABASE_S3_ENDPOINT="https://your-project.supabase.co/storage/v1/s3"
# SUPABASE_REGION="ap-southeast-1"
# SUPABASE_ACCESS_KEY_ID="supabase-access-key"
# SUPABASE_SECRET_ACCESS_KEY="supabase-secret-key"
# SUPABASE_BUCKET_NAME="falsisters-bucket"

# --- Vercel (auto-set, do not configure manually) ---
# When VERCEL=1, Prisma uses connection_limit=1 for serverless.
# This is set automatically by the Vercel runtime.
# VERCEL=1
